<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="chat.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:chat"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="chat">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="12" RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="6">
                <TextBlock Text="BLE / Wi-Fi Direct チャット" FontSize="18" FontWeight="SemiBold" />
                <TextBlock x:Name="LocalSessionText" TextWrapping="Wrap" />
                <TextBlock x:Name="BleStatusText" Text="BLE: Advertising Stopped / Scanning Stopped" TextWrapping="Wrap" />
                <TextBlock x:Name="WifiStatusText" Text="Wi-Fi Direct: Stopped / 未接続" TextWrapping="Wrap" />
                <TextBlock x:Name="ErrorText" Foreground="IndianRed" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button
                    x:Name="StartAdvertiseButton"
                    Content="BLE Advertise 開始"
                    Click="StartAdvertiseButton_Click" />
                <Button
                    x:Name="StopAdvertiseButton"
                    Content="停止"
                    IsEnabled="False"
                    Click="StopAdvertiseButton_Click" />
                <Button
                    x:Name="StartScanButton"
                    Content="BLE Scan 開始"
                    Click="StartScanButton_Click" />
                <Button
                    x:Name="StopScanButton"
                    Content="停止"
                    IsEnabled="False"
                    Click="StopScanButton_Click" />
                <Button
                    x:Name="StartWifiButton"
                    Content="Wi-Fi Direct 開始"
                    Click="StartWifiButton_Click" />
                <Button
                    x:Name="StopWifiButton"
                    Content="停止"
                    IsEnabled="False"
                    Click="StopWifiButton_Click" />
                <Button
                    x:Name="ConnectWifiButton"
                    Content="選択 peer に接続"
                    IsEnabled="False"
                    Click="ConnectWifiButton_Click" />
                <Button
                    x:Name="DisconnectWifiButton"
                    Content="切断"
                    IsEnabled="False"
                    Click="DisconnectWifiButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Grid RowDefinitions="Auto,*" RowSpacing="6">
                <TextBlock Text="発見済み peer" FontWeight="SemiBold" />
                <ListView
                    x:Name="PeerList"
                    Grid.Row="1"
                    DisplayMemberPath="DisplayText"
                    SelectionChanged="PeerList_SelectionChanged" />
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="6">
                <TextBlock Text="メッセージ一覧" FontWeight="SemiBold" />
                <ListView
                    x:Name="ChatList"
                    Grid.Row="1" />
            </Grid>
        </Grid>

        <Grid
            Grid.Row="2"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="8">

            <TextBox
                x:Name="MessageBox"
                PlaceholderText="メッセージを入力..."
                VerticalAlignment="Center" />

            <Button
                Grid.Column="1"
                Content="送信"
                Click="SendButton_Click" />
        </Grid>
    </Grid>
</Window>
