<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="chat.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:chat"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="P2P Chat">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" RequestedTheme="Dark">
    <!-- ======================================== -->
    <!-- リソース: チャットメッセージテンプレート -->
    <!-- ======================================== -->
        <Grid.Resources>
            <local:ChatMessageTemplateSelector x:Key="ChatTemplateSelector">
        <!-- 送信メッセージ (右寄せ) -->
                <local:ChatMessageTemplateSelector.SentTemplate>
                    <DataTemplate x:DataType="local:ChatMessageViewModel">
                        <Grid HorizontalAlignment="Right" Margin="80,3,12,3">
                            <Border Background="{ThemeResource ChatBubbleMeBrush}"
                                    CornerRadius="18,18,4,18" Padding="14,10">
                                <StackPanel MaxWidth="420">
                                    <TextBlock Text="{x:Bind Message}" FontSize="14"
                                               Foreground="{ThemeResource ChatBubbleMeTextBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{x:Bind Timestamp}" FontSize="10"
                                               Foreground="{ThemeResource ChatBubbleMeTextBrush}"
                                               Opacity="0.6" HorizontalAlignment="Right"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </local:ChatMessageTemplateSelector.SentTemplate>

        <!-- 受信メッセージ (左寄せ、アイコン付き) -->
                <local:ChatMessageTemplateSelector.ReceivedTemplate>
                    <DataTemplate x:DataType="local:ChatMessageViewModel">
                        <Grid HorizontalAlignment="Left" Margin="12,3,80,3">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                    <!-- アイコン -->
                                <Border Width="36" Height="36" CornerRadius="18"
                                        Background="{ThemeResource AccentBrush}"
                                        VerticalAlignment="Top" Margin="0,2,0,0">
                                    <TextBlock Text="{x:Bind SenderInitial}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                </Border>
                    <!-- 吹き出し -->
                                <Border Background="{ThemeResource ChatBubblePeerBrush}"
                                        CornerRadius="18,18,18,4" Padding="14,10">
                                    <StackPanel MaxWidth="420">
                                        <TextBlock Text="{x:Bind Sender}" FontSize="12" FontWeight="Bold"
                                                   Foreground="{ThemeResource AccentBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{x:Bind Message}" FontSize="14"
                                                   Foreground="{ThemeResource ChatBubblePeerTextBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{x:Bind Timestamp}" FontSize="10"
                                                   Foreground="{ThemeResource SecondaryTextBrush}"
                                                   HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </local:ChatMessageTemplateSelector.ReceivedTemplate>
            </local:ChatMessageTemplateSelector>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition IsStaggeringEnabled="True" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <!-- ======================================================== -->
        <!-- 左サイドバー - 操作パネル                                  -->
        <!-- ======================================================== -->
        <Border Background="{ThemeResource SidebarBackgroundBrush}">
            <Grid RowDefinitions="Auto,*,Auto">

            <!-- アプリヘッダー -->
                <StackPanel Padding="16,18,16,12">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Width="40" Height="40" CornerRadius="20"
                                Background="{ThemeResource AccentBrush}">
                            <FontIcon Glyph="&#xE8BD;" FontSize="20" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="P2Pチャット" FontSize="17" FontWeight="Bold"
                                       Foreground="{ThemeResource PrimaryTextBrush}"/>
                            <TextBlock Text="BLE・Wi-Fi Direct" FontSize="11"
                                       Foreground="{ThemeResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- スクロール可能な操作パネル -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="14,0" Spacing="4">

                        <!-- 区切り線 -->
                        <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,0,0,10"/>

                        <!-- メイン探索ボタン -->
                        <Button x:Name="DiscoveryButton"
                                Click="DiscoveryButton_Click"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                Background="{ThemeResource AccentBrush}"
                                Foreground="White" CornerRadius="8" Padding="0,12"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon x:Name="DiscoveryButtonIcon" Glyph="&#xE11A;" FontSize="16"/>
                                <TextBlock x:Name="DiscoveryButtonText" Text="探索開始"
                                           FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <!-- 状態表示 -->
                        <StackPanel Spacing="6" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse x:Name="BleStatusDot" Width="8" Height="8"
                                         Fill="{ThemeResource SecondaryTextBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="BleStatusLabel" Text="BLE: 停止中" FontSize="11"
                                           Foreground="{ThemeResource SecondaryTextBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse x:Name="WifiStatusDot" Width="8" Height="8"
                                         Fill="{ThemeResource SecondaryTextBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="WifiStatusLabel" Text="Wi-Fi Direct: 停止中" FontSize="11"
                                           Foreground="{ThemeResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 区切り線 -->
                        <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,10,0,8"/>

                        <!-- 接続セクション -->
                        <TextBlock Text="接続" FontSize="11" FontWeight="Bold"
                                   Foreground="{ThemeResource SectionHeaderBrush}"
                                   Margin="4,0,0,6" CharacterSpacing="80"/>

                        <!-- 接続ボタン -->
                        <Button x:Name="ConnectWifiButton" IsEnabled="False"
                                Click="ConnectWifiButton_Click"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Background="{ThemeResource ButtonSuccessBrush}"
                                Foreground="White" CornerRadius="6" Padding="0,8"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE71B;" FontSize="13"/>
                                <TextBlock Text="相手に接続" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <!-- 切断ボタン -->
                        <Button x:Name="DisconnectWifiButton" IsEnabled="False"
                                Click="DisconnectWifiButton_Click"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Background="{ThemeResource ButtonDangerBrush}"
                                Foreground="White" CornerRadius="6" Padding="0,8"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE711;" FontSize="13"/>
                                <TextBlock Text="切断" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <!-- 区切り線 -->
                        <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,10,0,8"/>

                        <!-- 詳細設定 -->
                        <Expander Header="詳細設定" HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Padding="0" IsExpanded="False">
                            <StackPanel Spacing="4" Padding="4,8">
                                <!-- 広告トグル -->
                                <Border CornerRadius="6" Padding="8,4">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <FontIcon Glyph="&#xEC05;" FontSize="14"
                                                  Foreground="{ThemeResource SecondaryTextBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="BLE広告" Margin="10,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   Foreground="{ThemeResource PrimaryTextBrush}"/>
                                        <ToggleSwitch Grid.Column="2" x:Name="AdvertiseToggle"
                                                      OnContent="" OffContent="" MinWidth="0"
                                                      Toggled="AdvertiseToggle_Toggled"/>
                                    </Grid>
                                </Border>
                                <!-- スキャントグル -->
                                <Border CornerRadius="6" Padding="8,4">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <FontIcon Glyph="&#xE11A;" FontSize="14"
                                                  Foreground="{ThemeResource SecondaryTextBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="BLEスキャン" Margin="10,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   Foreground="{ThemeResource PrimaryTextBrush}"/>
                                        <ToggleSwitch Grid.Column="2" x:Name="ScanToggle"
                                                      OnContent="" OffContent="" MinWidth="0"
                                                      Toggled="ScanToggle_Toggled"/>
                                    </Grid>
                                </Border>
                                <!-- Wi-Fi Directトグル -->
                                <Border CornerRadius="6" Padding="8,4">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <FontIcon Glyph="&#xE701;" FontSize="14"
                                                  Foreground="{ThemeResource SecondaryTextBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Wi-Fi Direct" Margin="10,0"
                                                   VerticalAlignment="Center" FontSize="12"
                                                   Foreground="{ThemeResource PrimaryTextBrush}"/>
                                        <ToggleSwitch Grid.Column="2" x:Name="WifiServiceToggle"
                                                      OnContent="" OffContent="" MinWidth="0"
                                                      Toggled="WifiServiceToggle_Toggled"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Expander>

                        <!-- 区切り線 -->
                        <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,8,0,4"/>

                        <!-- エラー表示 -->
                        <TextBlock x:Name="ErrorText"
                                   Foreground="{ThemeResource ErrorBrush}"
                                   TextWrapping="Wrap" FontSize="12" Margin="4,0"
                                   Visibility="Collapsed"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- 下部: セッション情報とテーマ切替 -->
                <StackPanel Grid.Row="2" Padding="14,8,14,14" Spacing="10">
                    <Border Height="1" Background="{ThemeResource DividerBrush}"/>

                    <!-- セッション情報 -->
                    <StackPanel Spacing="3">
                        <TextBlock Text="セッション" FontSize="10" FontWeight="Bold"
                                   Foreground="{ThemeResource SectionHeaderBrush}"
                                   CharacterSpacing="80"/>
                        <TextBlock x:Name="LocalSessionText" FontSize="11"
                                   Foreground="{ThemeResource SecondaryTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   IsTextSelectionEnabled="True"/>
                    </StackPanel>

                    <!-- テーマ切替 -->
                    <Border CornerRadius="6" Padding="8,4">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon x:Name="ThemeIcon" Glyph="&#xE708;" FontSize="16"
                                      Foreground="{ThemeResource SecondaryTextBrush}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="ThemeLabel" Text="ダークモード"
                                       Margin="12,0" VerticalAlignment="Center" FontSize="13"
                                       Foreground="{ThemeResource PrimaryTextBrush}"/>
                            <ToggleSwitch Grid.Column="2" x:Name="ThemeToggle" IsOn="True"
                                          OnContent="" OffContent="" MinWidth="0"
                                          Toggled="ThemeToggle_Toggled"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======================================================== -->
        <!-- 中央: 相手一覧                                             -->
        <!-- ======================================================== -->
        <Border Grid.Column="1" Background="{ThemeResource PeerListBackgroundBrush}"
                BorderBrush="{ThemeResource DividerBrush}" BorderThickness="1,0">
            <Grid RowDefinitions="Auto,*">

                <!-- 見出し -->
                <StackPanel Padding="16,16,16,10" Spacing="2">
                    <TextBlock Text="相手" FontSize="11" FontWeight="Bold"
                               Foreground="{ThemeResource SectionHeaderBrush}"
                               CharacterSpacing="80"/>
                    <TextBlock x:Name="PeerCountText" Text="0 台発見" FontSize="11"
                               Foreground="{ThemeResource SecondaryTextBrush}"/>
                </StackPanel>

                <!-- 相手一覧 -->
                <ListView x:Name="PeerList" Grid.Row="1" Padding="6,0"
                          SelectionChanged="PeerList_SelectionChanged">
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition />
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </ListView.ItemContainerTransitions>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="CornerRadius" Value="6"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,8" ColumnDefinitions="Auto,*">
                                <!-- 相手アイコン -->
                                <Border Width="38" Height="38" CornerRadius="19"
                                        Background="{ThemeResource AccentBrush}">
                                    <TextBlock Text="{Binding Initial}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" FontWeight="Bold" FontSize="16"/>
                                </Border>
                                <!-- 相手情報 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="12,0,0,0" Spacing="2">
                                    <TextBlock Text="{Binding ShortId}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource PrimaryTextBrush}"/>
                                    <TextBlock Text="{Binding RssiText}" FontSize="11"
                                               Foreground="{ThemeResource SecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding WifiStatusText}" FontSize="11"
                                               Foreground="{ThemeResource SecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- ======================================================== -->
        <!-- 右側 - チャット領域                                        -->
        <!-- ======================================================== -->
        <Grid Grid.Column="2" Background="{ThemeResource AppBackgroundBrush}"
              RowDefinitions="Auto,*,Auto">

            <!-- チャットヘッダー -->
            <Border Background="{ThemeResource ChannelHeaderBrush}" Padding="20,14"
                    BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8BD;" FontSize="18"
                                  Foreground="{ThemeResource SecondaryTextBrush}"/>
                        <TextBlock Text="チャット" FontSize="16" FontWeight="Bold"
                                   Foreground="{ThemeResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- 接続状態 -->
                    <Border Grid.Column="2" CornerRadius="12" Padding="10,4"
                            Background="{ThemeResource InputBackgroundBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse x:Name="ConnectionStatusDot" Width="8" Height="8"
                                     Fill="{ThemeResource ErrorBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ConnectionStatusLabel" Text="未接続" FontSize="12"
                                       Foreground="{ThemeResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- チャットメッセージ一覧 -->
            <ListView x:Name="ChatList" Grid.Row="1" Padding="8,8"
                      SelectionMode="None"
                      ItemTemplateSelector="{StaticResource ChatTemplateSelector}">
                <ListView.ItemContainerTransitions>
                    <TransitionCollection>
                        <AddDeleteThemeTransition />
                        <EntranceThemeTransition IsStaggeringEnabled="True"/>
                    </TransitionCollection>
                </ListView.ItemContainerTransitions>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- メッセージ入力欄 -->
            <Border Grid.Row="2" Margin="16,0,16,16">
                <Border Background="{ThemeResource InputBackgroundBrush}"
                        CornerRadius="8" Padding="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="MessageBox"
                                 PlaceholderText="メッセージを入力..."
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 Padding="12,8"
                                 FontSize="14"
                                 Foreground="{ThemeResource PrimaryTextBrush}"
                                 KeyDown="MessageBox_KeyDown"/>
                        <Button Grid.Column="1" x:Name="SendBtn"
                                Click="SendButton_Click"
                                Background="{ThemeResource AccentBrush}"
                                Foreground="White"
                                CornerRadius="6"
                                Padding="16,8"
                                Margin="4,0,0,0">
                            <FontIcon Glyph="&#xE724;" FontSize="16"/>
                        </Button>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>
