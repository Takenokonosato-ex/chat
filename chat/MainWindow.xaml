<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="chat.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="BLE Direct Chat"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="Root"
        Padding="20"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        RowDefinitions="Auto,*"
        RowSpacing="16">

        <Grid.Resources>
            <Style x:Key="SectionTitleText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            </Style>

            <Style x:Key="SubtleText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="PanelBorder" TargetType="Border">
                <Setter Property="Padding" Value="16" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </Grid.Resources>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="BLE Direct Chat" />
                <TextBlock
                    x:Name="LocalSessionText"
                    Style="{StaticResource SubtleText}" />
            </StackPanel>

            <ToggleSwitch
                x:Name="ThemeToggle"
                Grid.Column="1"
                Header="ダークモード"
                OffContent="ライト"
                OnContent="ダーク"
                Toggled="ThemeToggle_Toggled"
                VerticalAlignment="Center" />
        </Grid>

        <Grid
            Grid.Row="1"
            ColumnDefinitions="320,*,1.25*"
            ColumnSpacing="16">

            <Border Style="{StaticResource PanelBorder}">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource SectionTitleText}" Text="接続" />
                        <TextBlock
                            x:Name="BleStatusText"
                            Style="{StaticResource SubtleText}"
                            Text="BLE: 広告停止 / スキャン停止" />
                        <TextBlock
                            x:Name="WifiStatusText"
                            Style="{StaticResource SubtleText}"
                            Text="Wi-Fi Direct: 停止 / 未接続" />
                    </StackPanel>

                    <InfoBar
                        x:Name="ErrorBar"
                        Grid.Row="1"
                        IsOpen="False"
                        Severity="Error" />

                    <Grid
                        Grid.Row="2"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="8"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        RowSpacing="8">
                        <Button
                            x:Name="StartAdvertiseButton"
                            HorizontalAlignment="Stretch"
                            Click="StartAdvertiseButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE702;" />
                                <TextBlock Text="広告開始" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="StopAdvertiseButton"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Click="StopAdvertiseButton_Click"
                            IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE71A;" />
                                <TextBlock Text="停止" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="StartScanButton"
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            Click="StartScanButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE721;" />
                                <TextBlock Text="スキャン" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="StopScanButton"
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Click="StopScanButton_Click"
                            IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE71A;" />
                                <TextBlock Text="停止" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="StartWifiButton"
                            Grid.Row="2"
                            HorizontalAlignment="Stretch"
                            Click="StartWifiButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE701;" />
                                <TextBlock Text="Wi-Fi Direct" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="StopWifiButton"
                            Grid.Row="2"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Click="StopWifiButton_Click"
                            IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE71A;" />
                                <TextBlock Text="停止" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="ConnectWifiButton"
                            Grid.Row="3"
                            HorizontalAlignment="Stretch"
                            Click="ConnectWifiButton_Click"
                            IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE8CE;" />
                                <TextBlock Text="接続" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="DisconnectWifiButton"
                            Grid.Row="3"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Click="DisconnectWifiButton_Click"
                            IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE711;" />
                                <TextBlock Text="切断" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock
                        Grid.Row="3"
                        Style="{StaticResource SubtleText}"
                        Text="両方のPCで広告とスキャンを開始し、Wi-Fi Directが見つかった相手を選択してください。" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorder}">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Style="{StaticResource SectionTitleText}" Text="相手一覧" />
                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource SubtleText}"
                            Text="BLE + Wi-Fi Direct" />
                    </Grid>

                    <ListView
                        x:Name="PeerList"
                        Grid.Row="1"
                        DisplayMemberPath="DisplayText"
                        SelectionChanged="PeerList_SelectionChanged" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                    <TextBlock Style="{StaticResource SectionTitleText}" Text="メッセージ" />

                    <ListView
                        x:Name="ChatList"
                        Grid.Row="1" />

                    <Grid
                        Grid.Row="2"
                        ColumnDefinitions="*,Auto,Auto"
                        ColumnSpacing="8">
                        <TextBox
                            x:Name="MessageBox"
                            MinHeight="44"
                            KeyDown="MessageBox_KeyDown"
                            PlaceholderText="メッセージを入力..."
                            VerticalAlignment="Center" />

                        <Button
                            x:Name="PickFileButton"
                            Grid.Column="1"
                            MinHeight="44"
                            Click="PickFileButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE8E5;" />
                                <TextBlock Text="添付" />
                            </StackPanel>
                        </Button>

                        <Button
                            Grid.Column="2"
                            MinHeight="44"
                            Click="SendButton_Click"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="15" Glyph="&#xE724;" />
                                <TextBlock Text="送信" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
